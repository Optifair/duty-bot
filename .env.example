# Incoming Webhook URL из настроек Mattermost
MM_WEBHOOK_URL=https://your-mattermost.example.com/hooks/xxxxxxxxxxxxxxxxxx

# Имена/mentions через запятую — в том порядке, в котором идёт ротация
DUTY_PEOPLE=@alice,@bob,@charlie

# Время ежедневного сообщения (часовой пояс определяется TZ)
POST_HOUR=9
POST_MINUTE=0
TZ=Europe/Moscow
